{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "cloud.massdriver/mcp-server",
  "title": "Massdriver",
  "description": "Manage the Massdriver infrastructure platform: projects, environments, deployments, resources, policies, groups, OCI repos, and more.",
  "repository": {
    "url": "https://github.com/massdriver-cloud/mcp-server",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "docker.io/massdrivercloud/mcp-server:1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MASSDRIVER_API_KEY",
          "description": "Massdriver API key",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "MASSDRIVER_ORGANIZATION_ID",
          "description": "Massdriver organization ID",
          "format": "string",
          "isRequired": true
        },
        {
          "name": "MASSDRIVER_URL",
          "description": "Massdriver API URL. Only needed for self-hosted Massdriver instances.",
          "format": "string",
          "isRequired": false
        }
      ]
    }
  ]
}
